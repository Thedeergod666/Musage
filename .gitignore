# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Node
node_modules/
dist/
dist-ssr/
*.local

# Tauri / Rust
src-tauri/target/
src-tauri/gen/
# Cargo.lock: Tauri 是 binary app(不是 lib),必须 commit 锁版本,否则 CI 必炸
# Tauri 默认模板会 ignore 它,这里要主动 un-ignore

# Tauri updater signing key（私钥，绝不提交！）
# 用 tauri signer generate 生成
*.tauri.key
musage.key
tauri-updater-key*

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Local config
.env
.env.local
*.local

# User data
*.tmp

# macOS resource forks & Finder metadata
._*
.AppleDouble
.LSOverride
Icon?
.Spotlight-V100
.Trashes
.DocumentRevisions-V100*
.TemporaryItems
.fseventsd
.Network Trash Folder

# Local-only docs / project notes
MIGRATION.html
CLAUDE.md
.kilo

# Backup of .git (used during history-rewrite operations like filter-repo)
.git.bak/