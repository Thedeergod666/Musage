{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Musage",
  "version": "0.1.0",
  "identifier": "com.musage.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "floating",
        "title": "Musage",
        "width": 300,
        "height": 80,
        "minWidth": 180,
        "minHeight": 100,
        "maxWidth": 420,
        "maxHeight": 800,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": true,
        "shadow": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "MiniMax Token Plan 实时用量监控",
    "longDescription": "桌面悬浮窗 + 系统托盘，实时显示 MiniMax M2 系列模型的 5h / 周用量"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Thedeergod666/Musage/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_OUTPUT_OF_TAURI_SIGNER_GENERATE",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
